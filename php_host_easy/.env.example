# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=purchase_approval

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-string

# ── App URL (no trailing slash) ───────────────────────────────────────────────
APP_URL=https://magenta-investments.com

# ── Microsoft 365 / Azure AD OAuth ───────────────────────────────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI to add: https://magenta-investments.com/api/ms-callback.php
AZURE_AD_TENANT_ID=your-tenant-id-here
AZURE_AD_CLIENT_ID=your-client-id-here
AZURE_AD_CLIENT_SECRET=your-client-secret-here

# ── Email / SMTP (Office 365) ─────────────────────────────────────────────────
# Leave SMTP_USER blank to disable email notifications
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=notifications@magenta-investments.com
SMTP_PASS=your-smtp-password-here
SMTP_FROM=notifications@magenta-investments.com
